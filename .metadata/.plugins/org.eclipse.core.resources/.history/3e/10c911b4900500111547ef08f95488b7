package game;

import main

public class Player {
	
	int x;
	int y;
	
	public setDefaultValues() {
		x = 100;
		y = 100;

	}
	
	public void moveUp() {
	    y -= tileSize;
	}

	public void moveDown() {
	    y += tileSize;
	}

	public void moveLeft() {
	    x -= tileSize;
	}

	public void moveRight() {
	    x += tileSize;
	}

}
