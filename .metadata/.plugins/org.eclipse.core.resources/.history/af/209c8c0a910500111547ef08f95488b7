package game;

public class Player {
	
	GamePanel gp;
	KeyHandler keyH;
	
	int x;
	int y;
	
	public Player() {
		this.gp = gp;
		this.keyH = keyH;
	}
	
	public setDefaultValues() {
		x = 100;
		y = 100;

	}
	
	public void moveUp() {
	    y -= gp.tileSize;
	}

	public void moveDown() {
	    y += tileSize;
	}

	public void moveLeft() {
	    x -= tileSize;
	}

	public void moveRight() {
	    x += tileSize;
	}

}
