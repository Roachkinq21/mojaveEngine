package game;

import main

public class Player {
	
	int x;
	int y;
	
	public setDefaultValues() {
		x = 100;
		y = 100;

	}
	
	public void moveUp() {
	    playerY -= tileSize;
	}

	public void moveDown() {
	    playerY += tileSize;
	}

	public void moveLeft() {
	    playerX -= tileSize;
	}

	public void moveRight() {
	    playerX += tileSize;
	}

}
