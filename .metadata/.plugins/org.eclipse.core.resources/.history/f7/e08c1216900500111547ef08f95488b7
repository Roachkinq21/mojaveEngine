package game;

import main

public class Player {
	
	public Player() {
		public void moveUp() {
		    playerY -= tileSize;
		}

		public void moveDown() {
		    playerY += tileSize;
		}

		public void moveLeft() {
		    playerX -= tileSize;
		}

		public void moveRight() {
		    playerX += tileSize;
		}
	}

}
